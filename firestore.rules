rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isAdmin() {
      return isLoggedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // ── Users ───────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isLoggedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Run Events ──────────────────────────────────────────
    match /run_events/{eventId} {
      allow read: if isLoggedIn();
      allow create, update, delete: if isAdmin();
    }

    // ── Slots ───────────────────────────────────────────────
    match /slots/{slotId} {
      allow read: if isLoggedIn();
      // Runners can create their own slot
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      // Runners can delete their own slot (cancel); admin can update (mark attendance)
      allow delete: if isLoggedIn() && resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    // ── Announcements ────────────────────────────────────────
    match /announcements/{annId} {
      allow read: if true; // public — visible on landing page
      allow create, update, delete: if isAdmin();
    }

    // ── Invite Codes ─────────────────────────────────────────
    match /invite_codes/{codeId} {
      // Anyone (even unauthenticated) can read to validate during signup
      allow read: if true;
      allow create: if isAdmin();
      // Allow update so signup flow can mark code as used
      allow update: if isLoggedIn() && request.resource.data.used == true;
      allow delete: if isAdmin();
    }

    // ── Leaderboard ──────────────────────────────────────────
    match /leaderboard/{docId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }
  }
}
